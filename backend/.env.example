# ===== 必填：AI 模型配置 =====
GOOGLE_API_KEY=your_google_api_key_here

# 中转站 base URL（可选，留空则直连 Google 官方）
# 例如：https://generativelanguage.googleapis.com
GEMINI_BASE_URL=

DEFAULT_MODEL_NAME=gemini-2.5-pro
# 默认图像生成模型（主流水线使用，建议填 t2i 文生图模型）
# Gemini 可选：gemini-2.5-flash-image / gemini-2.5-flash-image-preview / gemini-3.1-flash-image-preview / gemini-3-pro-image-preview
# fal.ai 可选：fal-ai/nano-banana
# Doubao t2i 可选：doubao-seedream-3-0-t2i-250415 / doubao-seedream-5-0-260128 / doubao-seedream-4-5-251128
DEFAULT_IMAGE_MODEL_NAME=doubao-seedream-3-0-t2i-250415
# PolishAgent 手动精炼专用模型（可填 i2i 图生图模型，留空则沿用 DEFAULT_IMAGE_MODEL_NAME）
# Doubao i2i 可选：doubao-seededit-3-0-i2i-250628
IMAGE_POLISH_MODEL_NAME=doubao-seededit-3-0-i2i-250628

# ===== 可选：OpenAI（使用 gpt-image 时填写）=====
OPENAI_API_KEY=

# ===== 可选：fal.ai（使用 fal-ai/* 模型时填写）=====
FAL_API_KEY=
# fal.ai 中转 URL（留空则直连官方 https://fal.run）
FAL_BASE_URL=

# ===== 可选：Doubao（使用 doubao-* 模型时填写）=====
DOUBAO_API_KEY=
# 豆包兼容 OpenAI 的 baseURL（示例：https://ark.cn-beijing.volces.com/api/v3）
DOUBAO_BASE_URL=

# ===== 服务器配置 =====
PORT=3000
NODE_ENV=development

# 允许的前端源（生产环境改为实际域名）
CORS_ORIGIN=http://localhost:5173

# ===== 数据目录（可选，无则自动降级为 none 检索模式）=====
# 指向 PaperBananaBench 数据集目录（含 diagram/ 和 plot/ 子目录）
DATA_DIR=

# 风格指南目录（默认指向原项目的 style_guides/ 目录）
STYLE_GUIDES_DIR=

# ===== 并发与限流 =====
MAX_CONCURRENT_JOBS=10
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=20

# ===== LLM 超时与重试 =====
# 文本生成超时（毫秒），默认 120000 = 120s
TEXT_TIMEOUT_MS=120000
# 图像生成超时（毫秒），默认 180000 = 180s
IMAGE_TIMEOUT_MS=180000
# 文本生成最大重试次数（包含第一次），默认 2
TEXT_MAX_RETRY_ATTEMPTS=2
# 是否启用“按输入长度动态延长文本超时”
TEXT_TIMEOUT_DYNAMIC_ENABLED=true
# 输入字符超过该阈值后开始增加超时时间
TEXT_TIMEOUT_BASE_CHARS=3000
# 每增加 N 字符，额外增加一次 TEXT_TIMEOUT_ADD_MS
TEXT_TIMEOUT_ADD_PER_CHARS=1000
# 每个字符分段额外增加的超时（毫秒）
TEXT_TIMEOUT_ADD_MS=10000
# 每张输入图片（多模态）额外增加超时（毫秒）
TEXT_TIMEOUT_PER_IMAGE_MS=15000
# 动态文本超时上限（毫秒）
TEXT_TIMEOUT_MAX_MS=240000

# ===== 日志 =====
LOG_LEVEL=info
